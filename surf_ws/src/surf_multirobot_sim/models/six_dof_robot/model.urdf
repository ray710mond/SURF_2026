<?xml version="1.0"?>
<robot name="surf_six_dof_robot">
  <material name="surf_green"><color rgba="0.08 0.55 0.38 1"/></material>
  <material name="orange"><color rgba="0.95 0.45 0.08 1"/></material>
  <material name="dark"><color rgba="0.05 0.05 0.05 1"/></material>
  <link name="base_link">
    <visual><geometry><box size="0.80 0.55 0.30"/></geometry><material name="surf_green"/></visual>
  </link>
  <link name="nose">
    <visual>
      <origin rpy="0 1.570796 0"/>
      <geometry><cylinder radius="0.18" length="0.30"/></geometry>
      <material name="orange"/>
    </visual>
  </link>
  <joint name="nose_visual_joint" type="fixed">
    <parent link="base_link"/><child link="nose"/><origin xyz="0.48 0 0"/>
  </joint>
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.12" length="0.15"/></geometry><material name="dark"/></visual>
  </link>
  <joint name="lidar_visual_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/><origin xyz="0 0 0.28"/>
  </joint>
</robot>
