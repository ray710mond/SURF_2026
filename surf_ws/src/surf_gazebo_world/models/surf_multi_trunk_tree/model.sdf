<?xml version="1.0"?>
<sdf version="1.9">
  <model name="surf_multi_trunk_tree">
    <static>true</static>
    <link name="tree">
      <!--
        Collision follows only the bole and three main leaders. Keeping the
        crown visual-only preserves the low, walkable clearance seen in the
        reference photos and avoids a large invisible obstacle for robots.
      -->
      <collision name="bole_collision">
        <pose>0 0 1.45 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.46</radius>
            <length>2.9</length>
          </cylinder>
        </geometry>
      </collision>
      <collision name="west_leader_collision">
        <pose>-0.66 0.05 4.02 0 -0.30 0</pose>
        <geometry>
          <cylinder>
            <radius>0.31</radius>
            <length>4.65</length>
          </cylinder>
        </geometry>
      </collision>
      <collision name="northeast_leader_collision">
        <pose>0.43 0.50 4.02 0 0.28 0.85</pose>
        <geometry>
          <cylinder>
            <radius>0.28</radius>
            <length>4.55</length>
          </cylinder>
        </geometry>
      </collision>
      <collision name="south_leader_collision">
        <pose>0.03 -0.55 3.92 0 0.26 -1.55</pose>
        <geometry>
          <cylinder>
            <radius>0.25</radius>
            <length>4.45</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="root_flare_visual">
        <pose>0 0 0.22 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.62</radius>
            <length>0.44</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.19 0.105 0.055 1</ambient>
          <diffuse>0.25 0.135 0.065 1</diffuse>
          <specular>0.025 0.02 0.015 1</specular>
        </material>
      </visual>
      <visual name="bole_visual">
        <pose>0 0 1.45 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.46</radius>
            <length>2.9</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.17 0.09 0.045 1</ambient>
          <diffuse>0.25 0.13 0.06 1</diffuse>
          <specular>0.02 0.015 0.01 1</specular>
        </material>
      </visual>
      <visual name="west_leader_visual">
        <pose>-0.66 0.05 4.02 0 -0.30 0</pose>
        <geometry>
          <cylinder>
            <radius>0.31</radius>
            <length>4.65</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.18 0.095 0.045 1</ambient>
          <diffuse>0.27 0.14 0.065 1</diffuse>
          <specular>0.02 0.015 0.01 1</specular>
        </material>
      </visual>
      <visual name="northeast_leader_visual">
        <pose>0.43 0.50 4.02 0 0.28 0.85</pose>
        <geometry>
          <cylinder>
            <radius>0.28</radius>
            <length>4.55</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.16 0.085 0.04 1</ambient>
          <diffuse>0.24 0.125 0.055 1</diffuse>
          <specular>0.02 0.015 0.01 1</specular>
        </material>
      </visual>
      <visual name="south_leader_visual">
        <pose>0.03 -0.55 3.92 0 0.26 -1.55</pose>
        <geometry>
          <cylinder>
            <radius>0.25</radius>
            <length>4.45</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.19 0.10 0.048 1</ambient>
          <diffuse>0.28 0.145 0.065 1</diffuse>
          <specular>0.02 0.015 0.01 1</specular>
        </material>
      </visual>

      <!-- Upper branches are visual detail and remain above robot height. -->
      <visual name="west_branch_visual">
        <pose>-2.10 0.24 6.70 0 -0.88 0</pose>
        <geometry>
          <cylinder>
            <radius>0.18</radius>
            <length>2.70</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.17 0.09 0.045 1</ambient>
          <diffuse>0.25 0.13 0.06 1</diffuse>
        </material>
      </visual>
      <visual name="northeast_branch_visual">
        <pose>1.76 1.45 6.57 0 0.76 0.65</pose>
        <geometry>
          <cylinder>
            <radius>0.17</radius>
            <length>2.75</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.16 0.085 0.04 1</ambient>
          <diffuse>0.24 0.125 0.055 1</diffuse>
