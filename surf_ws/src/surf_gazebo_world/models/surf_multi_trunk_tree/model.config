<?xml version="1.0"?>
<model>
  <name>SURF Multi-Trunk Tree</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>SURF</name>
  </author>
  <description>
    A mature, broad-canopied multi-trunk tree based on the trees around
    Caltech's Throop Memorial Garden. The foliage is visual-only while the
    main stems provide simplified collision geometry for mobile robots.
  </description>
</model>
